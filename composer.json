{
  "name": "vicky-project/users-module",
  "type":"laravel-module",
  "license": "MIT",
  "description": "Module for manage about user, authentication and authorization user, profile users.",
  "authors": [{
    "name": "Vicky Rahman",
    "email": "pratamavr@gmail.com"
  }],
  "require": {
    "php": "^8.2",
    "nwidart/laravel-modules": "^12.0",
    "joshbrw/laravel-module-installer": "^1.0",
    "laravel/ui": "^4.6",
    "laravel/sanctum": "^4.3",
    "spatie/laravel-permission": "^6.24",
    "laravolt/avatar": "^6.3",
    "rappasoft/laravel-authentication-log": "^6.0",
    "spatie/laravel-activitylog": "^4.10",
    "vicky-project/coreui-module": "^1.0"
  },
  "extra": {
    "laravel": {
      "providers": ["Modules\\Users\\Providers\\UsersServiceProvider"],
      "aliases": {}
    }
  },
  "autoload": {
    "psr-4": {
      "Modules\\Users\\": "app/",
      "Modules\\Users\\Database\\Factories\\": "database/factories/",
      "Modules\\Users\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Modules\\Users\\Tests\\": "tests/"
    }
  }
}